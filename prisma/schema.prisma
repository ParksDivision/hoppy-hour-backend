generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GoogleRawBusiness {
  id            String    @id @default(uuid())
  googlePlaceId String?   @unique @map("google_place_id") @db.VarChar(255)
  name          String?   @db.VarChar(255)
  addressFull   Json?     @map("address_full")
  location      Json?     @map("location")
  primaryPhone  String?   @map("primary_phone") @db.VarChar(50)
  uri           String?   @db.VarChar(500)
  data          Json?
  createdOn     DateTime? @map("created_on") @db.Timestamp()
  createdBy     String?   @map("created_by") @db.VarChar(50)
  updatedOn     DateTime? @map("updated_on") @db.Timestamp()
  updatedBy     String?   @map("updated_by") @db.VarChar(50)

  // Relations with cascade delete
  businessesAustin BusinessAustin[]
  socialLinks      BusinessSocialLink?
  rawDealAnalysis  RawDealAnalysisAustin[]
  pendingDeals     PendingDealAustin?
  productionDeals  ProductionDealAustin?
  instagramRawData InstagramRawData?
  facebookRawData  FacebookRawData?
  twitterRawData   TwitterRawData?

  @@map("google_raw_business")
}

model BusinessSocialLink {
  id                  String    @id @default(uuid())
  googleRawBusinessId String    @map("google_raw_business_id")
  websiteUrl          String?   @map("website_url") @db.VarChar(500)
  facebookUrl         String?   @map("facebook_url") @db.VarChar(500)
  instagramUrl        String?   @map("instagram_url") @db.VarChar(500)
  twitterUrl          String?   @map("twitter_url") @db.VarChar(500)
  scrapedAt           DateTime? @map("scraped_at") @db.Timestamp()
  scrapeMethod        String?   @map("scrape_method") @db.VarChar(20)
  scrapeStatus        String?   @map("scrape_status") @db.VarChar(20)
  errorMessage        String?   @map("error_message") @db.VarChar(500)
  rawLinksFound       Json?     @map("raw_links_found")
  createdOn           DateTime? @map("created_on") @db.Timestamp()
  createdBy           String?   @map("created_by") @db.VarChar(50)
  updatedOn           DateTime? @map("updated_on") @db.Timestamp()
  updatedBy           String?   @map("updated_by") @db.VarChar(50)

  googleRawBusiness GoogleRawBusiness @relation(fields: [googleRawBusinessId], references: [id], onDelete: Cascade)

  @@unique([googleRawBusinessId])
  @@map("business_social_links")
}

model YelpRawBusiness {
  id           String    @id @default(uuid())
  name         String?   @db.VarChar(75)
  addressFull  Json?     @map("address_full")
  primaryPhone String?   @map("primary_phone") @db.VarChar(30)
  uri          String?   @db.VarChar(150)
  data         Json?
  createdOn    DateTime? @map("created_on") @db.Timestamp()
  createdBy    String?   @map("created_by") @db.VarChar(50)
  updatedOn    DateTime? @map("updated_on") @db.Timestamp()
  updatedBy    String?   @map("updated_by") @db.VarChar(50)

  // Relations with cascade delete
  businessesAustin BusinessAustin[]

  @@map("yelp_raw_business")
}

model User {
  id        String    @id @default(uuid())
  email     String?   @db.VarChar(75)
  role      String?   @db.VarChar(50)
  createdOn DateTime? @map("created_on") @db.Timestamp()
  createdBy String?   @map("created_by") @db.VarChar(50)
  updatedOn DateTime? @map("updated_on") @db.Timestamp()
  updatedBy String?   @map("updated_by") @db.VarChar(50)

  @@map("users")
}

model BusinessAustin {
  id             String             @id @default(uuid())
  googlePlaceId  String?            @map("google_place_id")
  yelpId         String?            @map("yelp_id")
  name           String?            @db.VarChar(75)
  addressFull    Json?              @map("address_full")
  primaryPhone   String?            @map("primary_phone") @db.VarChar(30)
  uri            String?            @db.VarChar(150)
  createdOn      DateTime?          @map("created_on") @db.Timestamp()
  createdBy      String?            @map("created_by") @db.VarChar(50)
  updatedOn      DateTime?          @map("updated_on") @db.Timestamp()
  updatedBy      String?            @map("updated_by") @db.VarChar(50)

  // Relations with cascade delete
  googleRawBusiness GoogleRawBusiness? @relation(fields: [googlePlaceId], references: [id], onDelete: Cascade)
  yelpRawBusiness   YelpRawBusiness?   @relation(fields: [yelpId], references: [id], onDelete: Cascade)

  @@map("businesses_austin")
}

// ─── Deal Pipeline Tables ─────────────────────────────────────────────────────

/// Per-source AI analysis results (one row per business per source type).
/// Raw Claude output stored here before aggregation.
model RawDealAnalysisAustin {
  id                  String    @id @default(uuid())
  googleRawBusinessId String    @map("google_raw_business_id")
  sourceType          String    @map("source_type") @db.VarChar(30)
  sourceUrl           String?   @map("source_url") @db.VarChar(500)
  deals               Json?
  rawAiResponse       Json?     @map("raw_ai_response")
  aiModel             String?   @map("ai_model") @db.VarChar(50)
  aiPromptVersion     String?   @map("ai_prompt_version") @db.VarChar(20)
  analysisStatus      String?   @map("analysis_status") @db.VarChar(20)
  errorMessage        String?   @map("error_message") @db.VarChar(1000)
  analyzedAt          DateTime? @map("analyzed_at") @db.Timestamp()
  createdOn           DateTime? @map("created_on") @db.Timestamp()
  createdBy           String?   @map("created_by") @db.VarChar(50)
  updatedOn           DateTime? @map("updated_on") @db.Timestamp()
  updatedBy           String?   @map("updated_by") @db.VarChar(50)

  googleRawBusiness GoogleRawBusiness @relation(fields: [googleRawBusinessId], references: [id], onDelete: Cascade)

  @@unique([googleRawBusinessId, sourceType])
  @@map("raw_deal_analysis_austin")
}

/// Staging table: one row per business with aggregated, deduplicated deals.
/// Admin reviews here and sets published = true to push to production.
model PendingDealAustin {
  id                  String    @id @default(uuid())
  googleRawBusinessId String    @unique @map("google_raw_business_id")
  businessName        String?   @map("business_name") @db.VarChar(255)
  primarySource       String?   @map("primary_source") @db.VarChar(30)
  deals               Json?
  published           Boolean   @default(false)
  publishedAt         DateTime? @map("published_at") @db.Timestamp()
  publishedBy         String?   @map("published_by") @db.VarChar(50)
  createdOn           DateTime? @map("created_on") @db.Timestamp()
  createdBy           String?   @map("created_by") @db.VarChar(50)
  updatedOn           DateTime? @map("updated_on") @db.Timestamp()
  updatedBy           String?   @map("updated_by") @db.VarChar(50)

  googleRawBusiness GoogleRawBusiness @relation(fields: [googleRawBusinessId], references: [id], onDelete: Cascade)

  @@index([published])
  @@map("pending_deals_austin")
}

/// Production table: one row per business with live deals served to the frontend.
model ProductionDealAustin {
  id                  String    @id @default(uuid())
  googleRawBusinessId String    @unique @map("google_raw_business_id")
  businessName        String?   @map("business_name") @db.VarChar(255)
  primarySource       String?   @map("primary_source") @db.VarChar(30)
  deals               Json?
  publishedAt         DateTime? @map("published_at") @db.Timestamp()
  publishedBy         String?   @map("published_by") @db.VarChar(50)
  createdOn           DateTime? @map("created_on") @db.Timestamp()
  createdBy           String?   @map("created_by") @db.VarChar(50)
  updatedOn           DateTime? @map("updated_on") @db.Timestamp()
  updatedBy           String?   @map("updated_by") @db.VarChar(50)

  googleRawBusiness GoogleRawBusiness @relation(fields: [googleRawBusinessId], references: [id], onDelete: Cascade)

  @@map("production_deals_austin")
}

// ─── Social Raw Data Tables ───────────────────────────────────────────────────

model InstagramRawData {
  id                  String    @id @default(uuid())
  googleRawBusinessId String    @unique @map("google_raw_business_id")
  profileUrl          String?   @map("profile_url") @db.VarChar(500)
  username            String?   @db.VarChar(100)
  posts               Json?
  postCount           Int?      @map("post_count")
  fetchStatus         String?   @map("fetch_status") @db.VarChar(20)
  errorMessage        String?   @map("error_message") @db.VarChar(500)
  fetchedAt           DateTime? @map("fetched_at") @db.Timestamp()
  createdOn           DateTime? @map("created_on") @db.Timestamp()
  createdBy           String?   @map("created_by") @db.VarChar(50)
  updatedOn           DateTime? @map("updated_on") @db.Timestamp()
  updatedBy           String?   @map("updated_by") @db.VarChar(50)

  googleRawBusiness GoogleRawBusiness @relation(fields: [googleRawBusinessId], references: [id], onDelete: Cascade)

  @@map("instagram_raw_data")
}

model FacebookRawData {
  id                  String    @id @default(uuid())
  googleRawBusinessId String    @unique @map("google_raw_business_id")
  profileUrl          String?   @map("profile_url") @db.VarChar(500)
  pageSlug            String?   @map("page_slug") @db.VarChar(100)
  posts               Json?
  postCount           Int?      @map("post_count")
  fetchStatus         String?   @map("fetch_status") @db.VarChar(20)
  errorMessage        String?   @map("error_message") @db.VarChar(500)
  fetchedAt           DateTime? @map("fetched_at") @db.Timestamp()
  createdOn           DateTime? @map("created_on") @db.Timestamp()
  createdBy           String?   @map("created_by") @db.VarChar(50)
  updatedOn           DateTime? @map("updated_on") @db.Timestamp()
  updatedBy           String?   @map("updated_by") @db.VarChar(50)

  googleRawBusiness GoogleRawBusiness @relation(fields: [googleRawBusinessId], references: [id], onDelete: Cascade)

  @@map("facebook_raw_data")
}

model TwitterRawData {
  id                  String    @id @default(uuid())
  googleRawBusinessId String    @unique @map("google_raw_business_id")
  profileUrl          String?   @map("profile_url") @db.VarChar(500)
  username            String?   @db.VarChar(100)
  tweets              Json?
  tweetCount          Int?      @map("tweet_count")
  fetchStatus         String?   @map("fetch_status") @db.VarChar(20)
  errorMessage        String?   @map("error_message") @db.VarChar(500)
  fetchedAt           DateTime? @map("fetched_at") @db.Timestamp()
  createdOn           DateTime? @map("created_on") @db.Timestamp()
  createdBy           String?   @map("created_by") @db.VarChar(50)
  updatedOn           DateTime? @map("updated_on") @db.Timestamp()
  updatedBy           String?   @map("updated_by") @db.VarChar(50)

  googleRawBusiness GoogleRawBusiness @relation(fields: [googleRawBusinessId], references: [id], onDelete: Cascade)

  @@map("twitter_raw_data")
}
